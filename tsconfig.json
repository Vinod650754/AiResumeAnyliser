{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "ignoreDeprecations": "6.0",
    "maxNodeModuleJsDepth": 0,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "client/src/**/*",
    "server/src/**/*",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "client/dist",
    "server/dist"
  ]
}
